  ('sentimental', 'Sentiment', s.research_sentimental),
] %}
### 2.{{ loop.index }} {{ label }}{% if report %} (total {{ report.total_score }} → {{ report.verdict }}, confidence {{ '%.2f' | format(report.confidence) }}){% else %} (not produced){% endif %}

